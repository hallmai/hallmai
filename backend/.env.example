# Database (docker compose up으로 자동 생성)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=hallmai

# JWT
JWT_SECRET=hallmai-dev-secret-key
JWT_EXPIRES_IN=7d

# Google OAuth (Required)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Google Gemini (Required)
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash              # Fallback for both voice/text
# GEMINI_VOICE_MODEL=gemini-live-2.5-flash-native-audio
# GEMINI_TEXT_MODEL=gemini-2.5-flash          # Soul extraction, story cards

# YouTube Data API v3 (Optional — F-31 대화 중 유튜브 검색)
# YOUTUBE_API_KEY=your-youtube-api-key-here

# Server (Optional)
# PORT=4000
# CORS_ORIGIN=http://localhost:3000
# NODE_ENV=development
